    "@medusajs/framework": "2.17.0",
    "@medusajs/icons": "2.17.0",
    "@medusajs/js-sdk": "2.17.0",
    "@medusajs/medusa": "2.17.0",
    "@medusajs/test-utils": "2.17.0",
    "@medusajs/ui": "4.1.15",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "13.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.17.0",
